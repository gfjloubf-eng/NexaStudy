# ===== NestJS Environment =====
NODE_ENV=development
PORT=3000

# ===== API =====
API_VERSION=v1

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173
CORS_ENABLED=true

# ===== Security =====
# Set to true to enable/require additional hardening in main.ts
HELMET_ENABLED=true

# ===== Compression =====
COMPRESSION_ENABLED=true

# ===== Logging (structured) =====
# Uses nestjs-pino
LOG_LEVEL=info
LOG_PRETTY=true

